DATABASE_URL=
ANTHROPIC_API_KEY=
CRON_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000
PHANTOMBUSTER_API_KEY=

# --- Phase 1 (engine upgrade) ---
OPENROUTER_API_KEY=
# Per-step model selection for the LLM factory (U1). Drafting cheap, judge/classify stronger.
# The stronger judge/classify pick is chosen by the U14 benchmark
# (src/scripts/benchmark-models.ts, docs/rubric/model-benchmark-results.md). Until the
# scoring run lands, deepseek is the placeholder; the recommended stronger model to
# confirm/beat is anthropic/claude-3.5-sonnet (~1 call per output).
LLM_MODEL_DRAFT=deepseek/deepseek-chat
LLM_MODEL_JUDGE=deepseek/deepseek-chat
LLM_MODEL_CLASSIFY=deepseek/deepseek-chat
# DIRECT (non-pooled) connection to the Neon DB for the worker + pg-boss (KTD2/KTD3).
# Derive from your pooled URL by removing "-pooler" from the host.
WORKER_DATABASE_URL_DIRECT=
# Optional healthchecks.io dead-man's-switch URL (U6). Empty = disabled.
HEALTHCHECK_PING_URL=
